# Windmill backend used by the MCP server.
WINDMILL_BASE_URL=https://app.windmill.dev
WINDMILL_WORKSPACE=lusopay-mcp-server
WINDMILL_TOKEN=replace_with_windmill_token

# Auth mode used by the MCP server.
# - static: local/dev mapping from access token to merchant
# - introspection: production, validates token with LusoPay auth endpoint
# - disabled: local development only
LUSOPAY_MCP_AUTH_MODE=static

# Token supplied to this MCP server by the merchant/client.
LUSOPAY_MCP_ACCESS_TOKEN=merchant-token-demo

# Static development mapping. Do not use this as the final production auth model.
LUSOPAY_MCP_MERCHANTS_JSON={"merchant-token-demo":{"merchant_id":"DEMO_STORE","merchant_name":"Loja Demo","permissions":["payments:read","customers:read","reconciliation:read"]}}

# Fallback merchant used only when auth is disabled or static mapping is omitted.
MERCHANT_ID=DEMO_STORE

# Production auth/introspection example.
# LUSOPAY_AUTH_INTROSPECTION_URL=https://api.lusopay.pt/oauth/introspect
# LUSOPAY_AUTH_SERVICE_TOKEN=replace_with_lusopay_internal_service_token
