{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "skipLibCheck": true,
    "lib": [
      "ES2022",
      "DOM"
    ]
  },
  "include": [
    "lib/**/*.ts",
    "lusopay/**/*.ts",
    "reconciliation/**/*.ts",
    "customers/**/*.ts",
    "f/**/*.ts"
  ],
  "extends": "./tsconfig.wmill.json"
}
