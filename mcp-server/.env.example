# Windmill backend used by the MCP server.
WINDMILL_BASE_URL=https://app.windmill.dev
WINDMILL_WORKSPACE=lusopay-mcp-server
WINDMILL_TOKEN=replace_with_windmill_token

# Auth mode used by the MCP server.
# - static: local/dev mapping from access token to merchant
# - introspection: production, validates token with LusoPay auth endpoint
# - disabled: local development only
LUSOPAY_MCP_AUTH_MODE=static

# Token supplied to this MCP server by the merchant/client.
LUSOPAY_MCP_ACCESS_TOKEN=merchant-token-demo

# Static development/pilot mapping.
# Prefer token_hash over storing merchant tokens in clear text.
LUSOPAY_MCP_MERCHANTS_JSON={"merchant-token-demo":{"merchant_id":"DEMO_STORE","merchant_name":"Loja Demo","permissions":["payments:read"]}}
# To expose criar_link_pagamento, grant payments:write explicitly:
# LUSOPAY_MCP_MERCHANTS_JSON={"merchant-token-demo":{"merchant_id":"DEMO_STORE","merchant_name":"Loja Demo","permissions":["payments:read","payments:write"]}}
# SaaS/pilot safer example:
# 1) npm run merchant:hash-token -- --merchant-id=DEMO_STORE --permissions=payments:read,payments:write --expires-at=2026-12-31T23:59:59Z
# 2) use only token_hash here:
# LUSOPAY_MCP_MERCHANTS_JSON=[{"token_hash":"sha256_here","merchant_id":"DEMO_STORE","merchant_name":"Loja Demo","permissions":["payments:read","payments:write"],"expires_at":"2026-12-31T23:59:59Z","active":true}]

# Fallback merchant used only when auth is disabled or static mapping is omitted.
MERCHANT_ID=DEMO_STORE

# Production auth/introspection example.
# LUSOPAY_AUTH_INTROSPECTION_URL=https://api.lusopay.pt/oauth/introspect
# LUSOPAY_AUTH_SERVICE_TOKEN=replace_with_lusopay_internal_service_token

# SaaS merchant registry used by Windmill scripts.
# In production this should be a secret variable/resource or database, not a committed file.
# LUSOPAY_MERCHANTS_VARIABLE_PATH=u/tomaspaiva/LUSOPAY_MERCHANTS_JSON
# LUSOPAY_MERCHANTS_JSON={"DEMO_STORE":{"merchant_name":"Loja Demo","lusopay":{"pid":"Cliente7","username":"Cliente7","password":"replace_with_secret","environment":"test"},"active":true}}
