# n8n release documented as stable on 2026-06-25.
N8N_VERSION=2.26.8
N8N_PORT=5678
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_EDITOR_BASE_URL=http://localhost:5678
WEBHOOK_URL=http://localhost:5678/
N8N_SECURE_COOKIE=false
GENERIC_TIMEZONE=Europe/Lisbon

# Generate with:
# powershell -NoProfile -Command "[Convert]::ToHexString((1..32 | ForEach-Object { Get-Random -Maximum 256 }))"
N8N_ENCRYPTION_KEY=replace-with-a-random-64-character-hex-value

# Avoid retaining successful payment payloads by default.
EXECUTIONS_DATA_SAVE_ON_SUCCESS=none
EXECUTIONS_DATA_SAVE_ON_ERROR=all
EXECUTIONS_DATA_MAX_AGE=168

# LusoPay Pay by Link V3.3.8.
# Production: https://app.lusopay.com:8443/web/api
LUSOPAY_BASE_URL=https://dev.lusopay.com:8444/web_dev/api
LUSOPAY_OWNER_ID=replace-with-merchant-public-account-id
LUSOPAY_DEFAULT_LANGUAGE=pt_PT
LUSOPAY_DEFAULT_PAYMENT_METHODS=P0
LUSOPAY_FINAL_URL=

# Adapter de loja V1. "mock" usa dados de exemplo até existir integração real.
STORE_ADAPTER_TYPE=mock
